[Unit]
Description=ArchMerOS reopen-history listener
After=graphical-session-pre.target
PartOf=graphical-session.target

[Service]
Type=simple
ExecStart=/usr/bin/python3 %h/.config/archmeros/scripts/archmeros-reopen-history.py listen
StandardOutput=append:/tmp/archmeros-reopen-listener.log
StandardError=append:/tmp/archmeros-reopen-listener.log
Restart=on-failure
RestartSec=1

[Install]
WantedBy=default.target
