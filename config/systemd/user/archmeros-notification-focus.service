[Unit]
Description=ArchMerOS notification focus dismiss listener
After=graphical-session-pre.target
PartOf=graphical-session.target

[Service]
Type=simple
ExecStart=/usr/bin/python3 %h/.config/archmeros/scripts/archmeros-notification-focus.py
StandardOutput=append:/tmp/archmeros-notification-focus.log
StandardError=append:/tmp/archmeros-notification-focus.log
Restart=on-failure
RestartSec=1

[Install]
WantedBy=default.target
