{
  "layer": "top",
  "position": "top",
  "exclusive": true,
  "height": 26,
  "spacing": 0,
  "margin": "0 0 4 0",
  "reload_style_on_change": true,
  "modules-left": [
    "hyprland/workspaces",
    // "wlr/taskbar",
    "custom/terminal",
    "tray"
  ],
  "modules-center": [
    "group/datetime"
  ],
  "modules-right": [
    "group/connectivity",
    "custom/keyboard",
    "group/system"
  ],
  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "on-click": "activate",
    "format": "{icon}",
    "format-icons": {
      "1": "I",
      "2": "II",
      "3": "III",
      "4": "IV",
      "5": "V",
      "6": "VI",
      "7": "VII",
      "8": "T",
      "9": "R"
    },
    "sort-by-number": true,
    "show-special": false,
    "ignore-workspaces": [
      "8",
      "9"
    ],
    "persistent-workspaces": {
      "*": [
        1,
        2,
        3,
        4,
        5
      ]
    }
  },
  "group/datetime": {
    "orientation": "inherit",
    "modules": [
      "clock#date",
      "clock#time"
    ]
  },
  "wlr/taskbar": {
    "all-outputs": false,
    "format": "{icon}",
    "icon-size": 15,
    "tooltip-format": "{name}: {title}",
    "on-click": "minimize-raise",
    "on-click-middle": "close",
    "active-first": false,
    "ignore-list": [
      "waybar",
      "dev.benz.walker",
      "it.mijorus.smile",
      "Rofi"
    ]
  },
  "group/connectivity": {
    "orientation": "inherit",
    "modules": [
      "network",
      "pulseaudio"
    ]
  },
  "group/system": {
    "orientation": "inherit",
    "modules": [
      "cpu",
      "memory",
      "battery"
    ]
  },
  "custom/terminal": {
    "format": "   TERM ",
    "tooltip": false,
    "on-click": "~/.config/archmeros/scripts/archmeros-terminal.sh"
  },
  "tray": {
    "icon-size": 16,
    "spacing": 0
  },
  "clock#date": {
    "interval": 3600,
    "format": "{:%a, %d %b %Y}",
    "tooltip": false,
    "on-click": "~/.config/archmeros/scripts/archmeros-calendar-popup.sh"
  },
  "clock#time": {
    "interval": 1,
    "format": "{:%I:%M:%S %p}",
    "tooltip-format": "{:%Ec}",
    "on-click": "~/.config/archmeros/scripts/archmeros-calendar-popup.sh"
  },
  "network": {
    "format-wifi": "▲ {bandwidthUpBytes} ▼ {bandwidthDownBytes}    {essid}",
    "format-ethernet": "▲ {bandwidthUpBytes} ▼ {bandwidthDownBytes}    ETH",
    "format-disconnected": "  offline",
    "tooltip-format": "{ifname}  {ipaddr}/{cidr}",
    "max-length": 36
  },
  "bluetooth": {
    "format": "  {status}",
    "format-connected": "  {num_connections}",
    "format-disabled": "  off",
    "tooltip-format": "{controller_alias}"
  },
  "pulseaudio": {
    "scroll-step": 2,
    "format": "{volume}% {icon}",
    "format-muted": "",
    "on-click": "pavucontrol",
    "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "format-icons": {
      "default": [
        "",
        ""
      ]
    }
  },
  "custom/keyboard": {
    "return-type": "json",
    "interval": 1,
    "exec": "~/.config/archmeros/scripts/archmeros-keyboard.sh",
    "on-click": "~/.config/archmeros/scripts/archmeros-keyboard.sh toggle",
    "tooltip": true
  },
  "cpu": {
    "interval": 2,
    "format": "{usage}% "
  },
  "memory": {
    "interval": 2,
    "format": "{}% "
  },
  "battery": {
    "interval": 30,
    "format": "{capacity}% ",
    "format-charging": "{capacity}% ",
    "states": {
      "warning": 30,
      "critical": 15
    }
  }
}
